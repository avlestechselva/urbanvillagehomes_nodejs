APP_NAME=UrbanVillageHomes
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/urbanvillagehomes

# Session
SESSION_SECRET=your-secret-key-here

# Jupix
JUPIX_URL=https://your-jupix-feed-url-here

# Stamp duty API
PROPERTY_DATA_API=https://api.propertydata.co.uk/stamp-duty?key=YOUR_KEY

# Mail (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mail_user
MAIL_PASS=your_mail_password
MAIL_FROM=info@urbanvillagehomes.com
MAIL_FROM_NAME=Urban Village Homes
MAIL_TO=info@urbanvillagehomes.com

# Google Maps
GOOGLE_MAPS_KEY=your-google-maps-api-key
