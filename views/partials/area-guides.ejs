<style>
    .area-guides-carousel {
        display: flex;
        overflow-x: auto;
        gap: 16px;
        padding: 20px 0;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }
    .area-guides-carousel::-webkit-scrollbar { height: 6px; }
    .area-guides-carousel::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
    .area-guide-item {
        flex: 0 0 280px;
        position: relative;
        border-radius: 9px;
        overflow: hidden;
        scroll-snap-align: start;
        cursor: pointer;
    }
    .area-guide-item img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }
    .area-guide-item::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.2);
        z-index: 1;
    }
    .area-guide-label {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 22px;
        font-weight: bold;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.7);
        z-index: 2;
        text-align: center;
        width: 100%;
    }
    .area-guide-item a.link-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 3;
    }
</style>

<div class="container-fluid my-5">
