<%- include('../includes/header') %>
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-9">
            <h1><%= post.title %></h1>
            <p class="text-muted"><%= post.createdAt ? new Date(post.createdAt).toDateString() : '' %></p>
            <% if (post.image) { %><img src="<%= post.image %>" class="img-fluid mb-4" alt="<%= post.title %>" onerror="this.src='/images/placeholder.svg'"><% } %>
            <div><%- post.body %></div>
        </div>
        <div class="col-lg-3">
            <a href="/market-updates" class="btn btn-outline-secondary mb-3">← Back to Market Updates</a>
        </div>
    </div>
</div>
<%- include('../includes/footer') %>
