<%- include('../includes/header') %>
<style type="text/css">
    label { float: left; }
</style>

<div aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/"><i class="fa fa-home"></i> Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Class List</li>
    </ol>
</div>

<div class="intro">
    <div class="container">
        <div class="row row-eq-height move_up_top">
            <div class="col-lg-6">
                <div class="section_title_container">
                    <h1 class="main-title">Class List</h1>
                </div>
                <div class="intro_content">
                    <div class="intro_text">
                        <p>Send your details to us, and we will donate to your preferred school once the sale or letting is completed</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 intro_col">
                <div class="intro_image">
                    <div class="hot_deal">
                        <div>&nbsp;</div>
                        <% if (typeof flash_success !== 'undefined' && flash_success) { %>
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="alert alert-success">
                                    <p><i class="fa fa-check-circle"></i> <strong>Success!!</strong> <%- flash_success %></p>
                                </div>
                            </div>
                        </div>
                        <% } %>
                        <form action="/send-class-list-request" method="post">
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" placeholder="Your name.." required />

                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" placeholder="Your email.." required />

                            <label for="phone">Phone</label>
                            <input type="text" id="phone" name="phone" placeholder="Your phone &nbsp;(Optional).." />

                            <label for="school">Preferred School</label>
                            <input type="text" id="school" name="school" placeholder="Your preferred school.." />

                            <label>Message</label>
                            <textarea class="contact_textarea contact_input" name="body_text" placeholder="Message"></textarea>

                            <div style="float: left !important;">
                                <div class="col-lg-12">
                                    <label class="chk-container">By submitting this form you agree to the terms of our <a href="/privacy-policy">Privacy Policy</a>
                                        <input type="checkbox" id="checkme" name="privacy" value="terms">
                                        <span class="checkmark"></span>
                                    </label>
                                    <label class="chk-container"> I would like to receive new events, invites and newsletters by email, from Urban Village Homes.
                                        <input type="checkbox" name="marketing" value="marketing">
                                        <span class="checkmark"></span>
                                    </label>
                                </div>
                            </div>
                            <input type="submit" disabled id="sendNewSms" value="Submit" />
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var checker = document.getElementById('checkme');
    var sendbtn = document.getElementById('sendNewSms');
    checker.onchange = function() {
        sendbtn.disabled = !this.checked;
    };
</script>

<%- include('../includes/footer') %>
