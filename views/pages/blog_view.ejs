<%- include('../includes/header') %>
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <h1><%= post.title %></h1>
            <p class="text-muted"><%= post.createdAt ? new Date(post.createdAt).toDateString() : '' %></p>
            <% if (post.image) { %><img src="<%= post.image %>" class="img-fluid mb-4" alt="<%= post.title %>"><% } %>
            <div><%- post.body %></div>
        </div>
        <div class="col-lg-4">
            <h4>Categories</h4>
            <ul class="list-unstyled">
                <% if (typeof categories !== 'undefined') { categories.forEach(function(cat) { %>
                <li><a href="/blog/<%= cat.slug %>"><%= cat.name %></a></li>
                <% }); } %>
            </ul>
        </div>
    </div>
</div>
<%- include('../partials/companies') %>
<%- include('../includes/footer') %>
