<%- include('../includes/header') %>

<div class="blog">
    <div class="container mt-5">
        <div class="row">
            <div class="col-lg-9">
                <h1 class="mb-4">Market Updates</h1>
                <% if (typeof posts !== 'undefined' && posts.length) { %>
                <% posts.forEach(function(post) { %>
                <div class="blog-card mb-4">
                    <% if (post.image) { %>
                    <a href="/blog/view/<%= post.slug %>">
                        <img src="<%= post.image %>" class="img-fluid mb-3" alt="<%= post.title %>" onerror="this.src='/images/placeholder.svg'">
                    </a>
                    <% } %>
                    <h2><a href="/blog/view/<%= post.slug %>"><%= post.title %></a></h2>
                    <p class="text-muted"><%= post.createdAt ? new Date(post.createdAt).toDateString() : '' %></p>
                    <p><%= post.excerpt || '' %></p>
                    <a href="/blog/view/<%= post.slug %>" class="btn btn-primary">Read More</a>
                </div>
                <% }); %>
                <% } else { %>
                <p>No market updates available.</p>
                <% } %>
            </div>
            <div class="col-lg-3">
                <h4>Latest News</h4>
                <% if (typeof posts !== 'undefined') { posts.forEach(function(post) { %>
                <div class="mb-3">
                    <a href="/blog/view/<%= post.slug %>" style="text-decoration:none;color:inherit;">
                        <strong><%= post.title %></strong>
                    </a>
                    <p class="text-muted small"><%= post.createdAt ? new Date(post.createdAt).toDateString() : '' %></p>
                </div>
                <% }); } %>
            </div>
        </div>
    </div>
</div>

<%- include('../includes/footer') %>
