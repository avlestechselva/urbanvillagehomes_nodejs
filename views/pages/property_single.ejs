<%- include('../includes/header') %>
<link rel="stylesheet" href="/css/new_aboutus.css">
<link rel="stylesheet" href="/css/page_header.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root {
    --primary-color: #982585; --text-primary: #000; --text-secondary: #404040;
    --text-light: #666; --border-color: #e5e7eb; --bg-light: #f9fafb; --bg-white: #fff;
    --shadow-sm: 0 1px 2px rgba(152,37,133,.05); --shadow-md: 0 4px 6px rgba(152,37,133,.1);
    --shadow-lg: 0 10px 15px rgba(152,37,133,.1); --radius-md: 8px; --radius-lg: 12px;
}
body { font-family:'Inter',-apple-system,sans-serif; color:var(--text-primary); line-height:1.6; }
.property-container { max-width:1200px; margin:0 auto; padding:0 20px; }
.property-header { background:#fff; border-radius:var(--radius-lg); box-shadow:var(--shadow-md); padding:20px 24px; margin-bottom:24px; border:1px solid var(--border-color); position:relative; overflow:hidden; }
.property-header::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:linear-gradient(90deg,var(--primary-color),#404040); }
.property-price { font-size:2rem; font-weight:800; color:var(--primary-color); margin-bottom:8px; }
.property-title { font-size:1.5rem; font-weight:700; color:var(--text-primary); margin-bottom:10px; text-decoration:none; display:block; }
.availability-badge { display:inline-flex; align-items:center; padding:4px 12px; background:#404040; color:#fff; font-size:.75rem; font-weight:600; border-radius:20px; text-transform:uppercase; margin-bottom:12px; }
.property-details { display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-top:8px; }
.detail-item { display:flex; align-items:center; gap:6px; color:var(--text-secondary); font-size:.95rem; }
.detail-item i { color:var(--primary-color); }
.image-gallery { background:#fff; border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-md); margin-bottom:24px; position:relative; }
.gallery-main img { width:100%; height:auto; max-height:500px; object-fit:contain; background:#f8f9fa; display:block; }
.gallery-controls { position:absolute; top:50%; transform:translateY(-50%); background:rgba(0,0,0,.5); color:#fff; border:none; width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; }
.gallery-prev { left:16px; } .gallery-next { right:16px; }
.gallery-dots { padding:16px; text-align:center; background:var(--bg-light); }
.gallery-dot { width:12px; height:12px; border-radius:50%; background:var(--border-color); border:none; margin:0 4px; cursor:pointer; }
.gallery-dot.active { background:var(--primary-color); }
.property-nav { display:flex; gap:8px; margin-bottom:32px; flex-wrap:wrap; justify-content:center; }
.nav-item { flex:1; min-width:120px; max-width:180px; }
.nav-link { display:flex; align-items:center; justify-content:center; gap:8px; padding:12px 16px; background:#fff; border:1px solid var(--border-color); border-radius:var(--radius-md); text-decoration:none; color:var(--text-secondary); font-size:.875rem; font-weight:500; transition:all .2s; }
.nav-link:hover { background:var(--primary-color); color:#fff; text-decoration:none; }
.nav-icon { width:20px; height:20px; }
.content-section { background:#fff; border-radius:var(--radius-lg); padding:24px; margin-bottom:24px; box-shadow:var(--shadow-sm); border:1px solid var(--border-color); }
.section-title { font-size:1.25rem; font-weight:600; margin-bottom:16px; padding-bottom:8px; border-bottom:2px solid var(--border-color); }
.description-text { color:var(--text-secondary); line-height:1.7; font-size:.95rem; }
.contact-info { color:var(--text-secondary); line-height:1.8; font-size:.9rem; }
.features-list { list-style:none; padding:0; margin:0; }
.features-list li { padding:8px 0 8px 24px; position:relative; color:var(--text-secondary); font-size:.9rem; border-bottom:1px solid var(--border-color); }
.features-list li:last-child { border-bottom:none; }
.features-list li::before { content:"✓"; position:absolute; left:0; color:#404040; font-weight:600; }
.resources-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; margin-top:24px; }
.resource-card { background:#fff; border:1px solid var(--border-color); border-radius:var(--radius-md); padding:20px; text-decoration:none; transition:all .2s; display:block; }
.resource-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-lg); border-color:var(--primary-color); text-decoration:none; }
.resource-header { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
.resource-icon { width:40px; height:40px; background:var(--primary-color); color:#fff; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
.resource-title { font-size:1.1rem; font-weight:600; color:var(--text-primary); margin:0; }
.resource-description { color:var(--text-secondary); font-size:.875rem; margin:0; }
.virtual-tour { background:#fff; border-radius:var(--radius-lg); padding:24px; margin-bottom:24px; box-shadow:var(--shadow-sm); border:1px solid var(--border-color); }
.embed-container { position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:var(--radius-md); }
.embed-container iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:0; }
.contact-form-section { background:var(--bg-light); padding:48px 0; margin-top:48px; }
.form-container { background:#fff; border-radius:var(--radius-lg); padding:32px; box-shadow:var(--shadow-md); border:1px solid var(--border-color); }
.form-title { font-size:1.75rem; font-weight:700; text-align:center; margin-bottom:32px; }
.form-group { margin-bottom:20px; }
.form-label { display:block; font-weight:500; margin-bottom:6px; font-size:.9rem; }
.form-input { width:100%; padding:12px 16px; border:1px solid var(--border-color); border-radius:var(--radius-md); font-size:.95rem; box-sizing:border-box; }
.form-input:focus { outline:none; border-color:var(--primary-color); }
.form-textarea { min-height:120px; resize:vertical; }
.checkbox-container { display:flex; align-items:flex-start; gap:8px; margin-top:16px; }
.checkbox-container label { font-size:.875rem; color:var(--text-secondary); }
.submit-btn { background:var(--primary-color); color:#fff; border:none; padding:14px 32px; border-radius:var(--radius-md); font-size:1rem; font-weight:600; cursor:pointer; width:100%; margin-top:16px; }
.submit-btn:disabled { background:var(--text-light); cursor:not-allowed; }
.map-container { border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-md); margin-top:24px; margin-bottom:48px; }
@media(max-width:576px) { .property-header { margin-top:85px; } .nav-item { flex:1; min-width:100px; } }
</style>

<div class="property-container" style="margin-top:30px;">
    <div class="property-header">
        <div class="header-content">
            <div class="property-main-info">
                <span class="availability-badge"><%= property.availability %></span>
                <div class="property-price">
                    £<% if (property.rent && property.rent > 0) { %><%= Number(property.rent).toLocaleString() %>/<%= property.rentFrequency || 'pcm' %><% } else { %><%= Number(property.price || 0).toLocaleString() %><% } %>
                </div>
                <a href="/property/<%= property.propertyID %>/<%= property.slug %>" class="property-title">
                    <%= property.displayAddress %>
                </a>
                <div class="property-details">
                    <% if (property.propertyBedrooms) { %>
                    <span class="detail-item"><i class="fa fa-bed"></i> <%= property.propertyBedrooms %> Bedrooms</span>
                    <span style="color:#666;">•</span>
                    <% } %>
                    <% if (property.propertyStyle) { %>
                    <span class="detail-item"><i class="fa fa-home"></i> <%= property.propertyStyle %></span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <% if (property.images && property.images.length) { %>
    <div class="image-gallery">
        <% property.images.forEach(function(image, k) { %>
        <div class="mySlides" style="display:<%= k === 0 ? 'block' : 'none' %>;">
            <div class="gallery-main">
                <img src="<%= image %>" alt="<%= property.displayAddress %> image <%= k+1 %>" onerror="this.src='/images/placeholder.svg'">
            </div>
        </div>
        <% }); %>
        <% if (property.images.length > 1) { %>
        <button class="gallery-controls gallery-prev" onclick="plusSlides(-1)">&#10094;</button>
        <button class="gallery-controls gallery-next" onclick="plusSlides(1)">&#10095;</button>
        <div class="gallery-dots">
            <% property.images.forEach(function(img, k) { %>
            <button class="gallery-dot <%= k === 0 ? 'active' : '' %>" onclick="currentSlide(<%= k+1 %>)"></button>
            <% }); %>
        </div>
        <% } %>
    </div>
    <% } %>

    <div class="property-nav">
        <div class="nav-item">
            <div class="nav-link">
                <span><%= property.availability %></span>
            </div>
        </div>
        <div class="nav-item">
            <a href="#features" class="nav-link"><span>Features</span></a>
        </div>
        <div class="nav-item">
            <a href="#resources" class="nav-link"><span>Documents</span></a>
        </div>
        <div class="nav-item">
            <a href="#location" class="nav-link"><span>Location</span></a>
        </div>
        <div class="nav-item">
            <a href="#contact" class="nav-link"><span>Contact</span></a>
        </div>
        <div class="nav-item">
            <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent('https://urbanvillagehomes.com/property/' + property.propertyID + '/' + property.slug) %>"
               target="_blank" class="nav-link" style="background:#25d366;color:#fff;border-color:#25d366;">
                <span>WhatsApp Share</span>
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="content-section">
                <h3 class="section-title">Description</h3>
                <div class="description-text"><%- property.mainSummary || '' %></div>
            </div>
        </div>
        <div class="col-lg-3 mb-4">
            <div class="content-section">
                <h3 class="section-title">Contact Agent</h3>
                <div class="contact-info">
                    <strong>Urban Village Homes Limited</strong><br>
                    121 Denmark Hill<br>Camberwell<br>London<br>SE5 8EN<br>United Kingdom<br>
                    Tel: <a href="tel:02035199121">020 3519 9121</a><br>
                    <a href="mailto:info@urbanvillagehomes.com">info@urbanvillagehomes.com</a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-4" id="features">
            <div class="content-section">
                <h3 class="section-title">Property Features</h3>
                <ul class="features-list">
                    <% for (var fi = 1; fi <= 10; fi++) { %>
                    <% if (property['propertyFeature' + fi]) { %>
                    <li><%- property['propertyFeature' + fi] %></li>
                    <% } %>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>

    <% if (property.virtualTours && property.virtualTours.length) { %>
    <div class="virtual-tour">
        <h3 class="section-title">Property Virtual Tour</h3>
        <% property.virtualTours.forEach(function(vt) { %>
        <div class="embed-container">
            <iframe src="<%= vt.virtualTour || vt %>" allowfullscreen></iframe>
        </div>
        <% }); %>
    </div>
    <% } %>

    <div class="content-section" id="resources">
        <h3 class="section-title">Documents &amp; Resources</h3>
        <div class="resources-grid">
            <% if (property.epcGraphs && property.epcGraphs.length) { property.epcGraphs.forEach(function(epc) { %>
            <a href="/view-resource/<%= epc %>" target="_blank" class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon"><i class="fa fa-bar-chart"></i></div>
                    <div>
                        <h4 class="resource-title">EPC Certificate</h4>
                        <p class="resource-description">Energy Performance Certificate</p>
                    </div>
                </div>
            </a>
            <% }); } %>
            <% if (property.floorplans && property.floorplans.length) { property.floorplans.forEach(function(fp) { %>
            <a href="/view-resource/<%= fp %>" target="_blank" class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon"><i class="fa fa-newspaper-o"></i></div>
                    <div>
                        <h4 class="resource-title">Floor Plan</h4>
                        <p class="resource-description"><%= property.displayAddress %></p>
                    </div>
                </div>
            </a>
            <% }); } %>
            <% if (property.brochures && property.brochures.length) { property.brochures.forEach(function(br, k) { %>
            <a href="/view-resource/<%= br %>" target="_blank" class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon"><i class="fa fa-book"></i></div>
                    <div>
                        <h4 class="resource-title">Property Brochure</h4>
                        <p class="resource-description">Brochure No <%= k+1 %></p>
                    </div>
                </div>
            </a>
            <% }); } %>
            <% if (property.externalLinks && property.externalLinks.length) { property.externalLinks.forEach(function(link, k) { %>
            <a href="<%= link.url %>" target="_blank" class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon"><i class="fa fa-external-link-square"></i></div>
                    <div>
                        <h4 class="resource-title"><%= link.description %></h4>
                        <p class="resource-description">External Link <%= k+1 %></p>
                    </div>
                </div>
            </a>
            <% }); } %>
        </div>
    </div>
</div>

<% if (property.availability !== 'Sold') { %>
<div class="contact-form-section" id="contact">
    <div class="property-container">
        <div class="form-container">
            <h2 class="form-title">Arrange a Viewing</h2>
            <form action="/send-valuation-request" method="POST">
                <input type="hidden" name="property_id" value="<%= property.propertyID %>">
                <input type="hidden" name="display_address" value="<%= property.displayAddress %>">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-input" name="name" placeholder="Enter your full name" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-input" name="email" placeholder="Enter your email" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Phone Number</label>
                            <input type="text" class="form-input" name="phone" placeholder="Enter your phone number" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Address</label>
                            <input type="text" class="form-input" name="address" placeholder="Enter your address" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Preferred Viewing Time</label>
                            <input type="text" class="form-input" name="preferr_date" placeholder="Select preferred date and time">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Message</label>
                            <textarea class="form-input form-textarea" name="body_text" placeholder="Tell us about your requirements..." required></textarea>
                        </div>
                        <div class="checkbox-container">
                            <input type="checkbox" id="privacy" name="privacy" value="terms" required>
                            <label for="privacy">I agree to the <a href="/privacy-policy">Privacy Policy</a></label>
                        </div>
                        <div class="checkbox-container">
                            <input type="checkbox" id="marketing" name="marketing" value="marketing">
                            <label for="marketing">I would like to receive updates from Urban Village Homes</label>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="submit-btn" id="sendNewSms" disabled>Submit Viewing Request</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>

<div class="property-container">
    <% if (property.latitude && property.longitude) { %>
    <div class="map-container" id="location">
        <iframe src="https://maps.google.com/maps?q=<%= property.latitude %>,<%= property.longitude %>&z=15&output=embed"
                width="100%" height="450" frameborder="0" allowfullscreen></iframe>
    </div>
    <% } %>
</div>

<script>
let slideIndex = 1;
function plusSlides(n) { showSlides(slideIndex += n); }
function currentSlide(n) { showSlides(slideIndex = n); }
function showSlides(n) {
    const slides = document.getElementsByClassName("mySlides");
    const dots = document.getElementsByClassName("gallery-dot");
    if (n > slides.length) slideIndex = 1;
    if (n < 1) slideIndex = slides.length;
    for (let i = 0; i < slides.length; i++) slides[i].style.display = "none";
    for (let i = 0; i < dots.length; i++) dots[i].classList.remove("active");
    if (slides[slideIndex-1]) slides[slideIndex-1].style.display = "block";
    if (dots[slideIndex-1]) dots[slideIndex-1].classList.add("active");
}
const privacyBox = document.getElementById('privacy');
if (privacyBox) privacyBox.addEventListener('change', function() {
    document.getElementById('sendNewSms').disabled = !this.checked;
});
document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
        e.preventDefault();
        const t = document.querySelector(this.getAttribute('href'));
        if (t) t.scrollIntoView({ behavior: 'smooth' });
    });
});
</script>

<%- include('../includes/footer') %>
